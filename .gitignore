# ============================================================
# FaceDiff .gitignore — Comprehensive (2026-05-17)
# ============================================================

# ── Data: Caches, LMDBs, Backups (CRITICAL: never push) ──
data/
data/slat_cache/
data/slat_cache_facescape/
data/ovoxel_cache_lmdb/
data/ovoxel_cache_recached/
data/backup_*/
data/*.lmdb/
*.lmdb/
*.mdb
*.lmdb-lock

# ── Data: Large binaries in data/ ──
data/mediapipe_models/
data/*.pt

# ── Data: Keep manifest + small configs ──
!data/mesh_manifest.json

# ── Model Checkpoints ──
checkpoints/
*.pt
*.pth
*.bin
*.safetensors
*.ckpt
*.onnx

# ── Training Outputs ──
outputs/
outputs_context_viz/
val_samples/
test_dc_diagnostic/
logs/
*.log
wandb/

# ── Conda / Python Environment ──
miniconda3/
snap/
__pycache__/
*.py[cod]
*$py.class
*.so
*.o
.Python
env/
venv/
.venv/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
pip-log.txt
pip-delete-this-directory.txt

# ── Third-party (vendored, tracked separately or via submodule) ──
third_party/

# ── IDEs & Editors ──
.vscode/
.vscode-server/
.idea/
.cursor/
.cursor-server/
.windsurf-server/
*.swp
*.swo
*~

# ── AI Agents & Tools ──
.gemini/
.claude/
.claude.json
CLAUDE.md
.cline/
.codeium/
.codex/
.copilot/
.antigravity-server/

# ── System & Dotfiles ──
.DS_Store
Thumbs.db
.ipynb_checkpoints/
.env
.netrc
.ssh/
.cache/
.config/
.local/
.conda/
.anaconda/
.dotnet/
.java/
.nv/
.triton/
.flex_gemm/
.insightface/
.bash_history
.bash_logout
.bashrc
.profile
.wget-hsts

# ── Temp / Scratch ──
*.tmp
*.bak
*.orig

# ── Papers / Docs binaries (large reference PDFs, không push) ──
docs/papers/
*.pdf

# ── Keep these ──
!.gitignore
!requirements.txt
!requirements-mamba.txt

# ============================================================
# FaceDiff .gitignore
# ============================================================

# ── Datasets & Caches (CRITICAL: never upload) ──
/data/
*.lmdb
*.mdb

# ── Model Checkpoints ──
checkpoints/
*.pt
*.pth
*.bin
*.safetensors
*.ckpt

# ── Training Outputs ──
outputs/
val_samples/
test_dc_diagnostic/
logs/
*.log
wandb/

# ── Conda / Python Environment ──
miniconda3/
snap/
__pycache__/
*.py[cod]
*$py.class
*.so
*.o
.Python
env/
venv/
.venv/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# ── Third-party (vendored separately) ──
third_party/

# ── IDEs & Editors ──
.vscode/
.vscode-server/
.idea/
.cursor/
.cursor-server/
.windsurf-server/

# ── AI Agents & Tools ──
.gemini/
.claude/
.claude.json
.cline/
.codeium/
.codex/
.copilot/
.antigravity-server/

# ── System & Dotfiles ──
.DS_Store
.ipynb_checkpoints
.env
.netrc
.ssh/
.cache/
.config/
.local/
.conda/
.anaconda/
.dotnet/
.java/
.nv/
.triton/
.flex_gemm/
.insightface/
.bash_history
.bash_logout
.bashrc
.profile
.wget-hsts

# ── Keep .gitignore itself ──
!.gitignore

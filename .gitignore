# ============================================================
# FaceDiff .gitignore — Comprehensive (Updated 2026-05-20)
# ============================================================

# ── Data: LMDB, caches, large binaries (never push) ──
# Use data/* (not data/) to allow traversal so !data/mesh_manifest.json works
data/*
!data/mesh_manifest.json
*.lmdb/
*.mdb
*.lmdb-lock

# ── Model checkpoints & weights ──
checkpoints/
*.pt
*.pth
*.bin
*.safetensors
*.ckpt
*.onnx

# ── Training outputs & logs ──
outputs/
outputs_*/
val_samples/
test_dc_diagnostic/
logs/
*.log
wandb/

# ── Python / Conda environments ──
miniconda3/
snap/
env/
venv/
.venv/
.conda/
.anaconda/
__pycache__/
*.py[cod]
*$py.class
*.so
*.o
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
pip-log.txt
pip-delete-this-directory.txt

# ── Third-party (vendored libraries, submodules) ──
third_party/

# ── IDEs & Editors ──
.vscode/
.vscode-server/
.idea/
.cursor/
.cursor-server/
.windsurf-server/
.antigravity-server/
.antigravity-ide-server/
.antigravity-*/
*.swp
*.swo
*~

# ── AI agents & tools ──
.gemini/
.claude/
.claude.json
.cline/
.codeium/
.codex/
.copilot/

# Keep .claude/skills/, .claude/plans/ ignored too (under .claude/)
# CLAUDE.md is a per-user instructions file
CLAUDE.md

# ── System & dotfiles ──
.DS_Store
Thumbs.db
.ipynb_checkpoints/
.env
.netrc
.ssh/
.cache/
.config/
.local/
.dotnet/
.java/
.nv/
.triton/
.flex_gemm/
.insightface/
.bash_history
.bash_logout
.bashrc
.profile
.wget-hsts

# ── Temp / scratch / backup ──
*.tmp
*.bak
*.orig
/tmp/
nohup.out

# ── Documentation binaries (PDFs, thesis drafts — not pushed) ──
docs/
*.pdf

# ── Force-keep (override above rules) ──
!.gitignore
!requirements.txt
!requirements-mamba.txt

#iFaceFlow 
iFaceFlow/